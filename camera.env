# Single stable MJPEG stream URL served by mjpg_streamer on the rover.
# The camera_service (port 9000) swaps which physical camera feeds this URL;
# the URL itself never changes so the browser <img> does not re-connect.
HUSKY_CAMERAS="field of view:http://100.80.12.52:8080/?action=stream"

# URL of the camera switching service running on the rover (camera_service.py).
# Leave blank to disable camera switching (site still shows the stream above).
HUSKY_CAM_SVC_URL="http://100.80.12.52:9000"

# Shared token sent as X-Camera-Token to the camera service.
# Must match CAMERA_SVC_TOKEN set on the rover when starting camera_service.py.
# Leave blank if auth is disabled on the service.
HUSKY_CAM_SVC_TOKEN=""

# Spectrometer data source.
#   mock  = synthetic test data (laptop dev, no hardware needed)
#   csv   = reads live color-band CSV from the Pi (competition)
HUSKY_SPECTROMETER_SOURCE="csv"

# Path to the color spectrometer CSV on the Pi.
HUSKY_COLOR_CSV_PATH="/home/robot/HR-pi/output_data/peaks_colors.csv"

# Path to the organic percentage CSV (leave blank if not wired up yet).
HUSKY_ORGANIC_PCT_CSV_PATH=""

# If set, /api/spectrum/latest proxies this Pi endpoint instead of reading local state.
HUSKY_SPECTRUM_API_URL="http://100.80.12.52:9001/spectrum"