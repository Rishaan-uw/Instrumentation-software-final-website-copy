# Single stable MJPEG stream URL served by mjpg_streamer on the rover.
HUSKY_CAMERAS="field of view:http://100.80.12.52:8080/?action=stream"

# Camera switching service (port 9000) — separate from robot service.
HUSKY_CAM_SVC_URL="http://100.80.12.52:9000"
HUSKY_CAM_SVC_TOKEN=""

# Pi robot service (port 9001): actions + sensor sampling + CSV reads.
HUSKY_ROBOT_SERVICE_URL="http://100.80.12.52:9001"
HUSKY_ROBOT_SERVICE_TOKEN=""
